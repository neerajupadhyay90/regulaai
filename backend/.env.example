# ─── Azure AI Foundry (Foundry IQ) ──────────────────────────────────
AZURE_FOUNDRY_ENDPOINT=https://your-project.openai.azure.com/
AZURE_FOUNDRY_API_KEY=your_foundry_api_key_here
AZURE_FOUNDRY_DEPLOYMENT=gpt-4o

# ─── Microsoft Fabric (Fabric IQ) ───────────────────────────────────
FABRIC_WORKSPACE_ID=your_fabric_workspace_id
FABRIC_LAKEHOUSE_ID=your_fabric_lakehouse_id
FABRIC_API_KEY=your_fabric_api_key

# ─── Azure Cosmos DB ────────────────────────────────────────────────
COSMOS_CONNECTION_STRING=AccountEndpoint=https://your-account.documents.azure.com:443/;AccountKey=your_key
COSMOS_DATABASE=regulaai
COSMOS_CONTAINER=reports

# ─── Anthropic (fallback for development) ───────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── App Config ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
